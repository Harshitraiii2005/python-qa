# Groq (free at console.groq.com)
GROQ_API_KEY=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

# Model options (all free on Groq):
#   llama-3.1-8b-instant      ← fastest, good for most questions
#   llama-3.3-70b-versatile   ← best quality
#   mixtral-8x7b-32768        ← great for code
LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=1024

# Embeddings (local, no API key needed)
EMBEDDING_MODEL=llama-3.3-70b-versatile

# Vector store path (local disk)
CHROMA_PERSIST_DIR=./chroma_db

# Data
DATA_PATH=./data/python_qa_sample.csv
MAX_DOCUMENTS=50000

# Retrieval
TOP_K=5

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
